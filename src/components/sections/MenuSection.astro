---
import MenuCard from '@components/islands/MenuCard';
import type { Menu, MenuCardTranslations } from '@/types/menu';

interface Props {
  translations: {
    pageTitle: string;
    pageSubtitle: string;
    menuLabel: string;
    dishesLabel: string;
    shareButtonText: string;
    sourceCredit: string;
    linkCopied: string;
  };
  initialMenu: Menu;
}

const { translations, initialMenu } = Astro.props;

const menuCardTranslations: MenuCardTranslations = {
  menuLabel: translations.menuLabel,
  dishesLabel: translations.dishesLabel,
  shareButtonText: translations.shareButtonText,
  linkCopied: translations.linkCopied,
};
---

<section
  id="menu"
  class="menu-section"
  aria-labelledby="menu-title"
>
  <div class="container">
    <header class="section-header">
      <h1 id="menu-title" class="section-title">
        {translations.pageTitle}
      </h1>
      <p class="section-subtitle">
        {translations.pageSubtitle}
      </p>
    </header>

    <div class="menu-card-wrapper">
      <MenuCard
        client:idle
        initialMenu={initialMenu}
        translations={menuCardTranslations}
      />
    </div>

    <footer class="source-credit">
      <p>{translations.sourceCredit}</p>
    </footer>
  </div>
</section>

<style>
  .menu-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-8) var(--spacing-4);
    background: linear-gradient(135deg, var(--color-primary-50) 0%, var(--color-secondary-50) 100%);
  }

  .container {
    width: 100%;
    max-width: 32rem;
    margin: 0 auto;
    text-align: center;
  }

  .section-header {
    margin-bottom: var(--spacing-8);
  }

  .section-title {
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--color-neutral-900);
    margin-bottom: var(--spacing-2);
  }

  @media (min-width: 640px) {
    .section-title {
      font-size: var(--text-4xl);
    }
  }

  .section-subtitle {
    font-size: var(--text-lg);
    color: var(--color-neutral-600);
  }

  .menu-card-wrapper {
    margin-bottom: var(--spacing-8);
  }

  .source-credit {
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
  }

  .source-credit p {
    margin: 0;
  }
</style>
